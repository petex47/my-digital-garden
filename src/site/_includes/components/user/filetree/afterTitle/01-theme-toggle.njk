<div class="petex-theme-toggle-wrap">
  <button id="petex-theme-toggle" class="petex-theme-toggle" type="button" aria-label="Toggle theme">
    <span>Theme</span>
    <span id="petex-theme-state">Light</span>
  </button>
</div>

<script>
(function () {
  function getTheme() {
    return localStorage.getItem("petex47-theme") || "dark";
  }

  function applyTheme(theme) {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("petex47-theme", theme);
    var state = document.getElementById("petex-theme-state");
    if (state) state.textContent = theme === "dark" ? "Dark" : "Light";
  }

  document.addEventListener("DOMContentLoaded", function () {
    applyTheme(getTheme());

    var btn = document.getElementById("petex-theme-toggle");
    if (!btn) return;

    btn.addEventListener("click", function () {
      var next = getTheme() === "dark" ? "light" : "dark";
      applyTheme(next);
    });
  });
})();
</script>
